+/// segment glows with the accent colour; inactive segments are dim. Clicking
+/// any segment sets the parameter immediately.
+fn shaper_switch(
+    ui: &mut egui::Ui,
+    current: Shaper,
+    setter: &ParamSetter,
+    param: &nih_plug::prelude::EnumParam<Shaper>,
+) {
+    let options: &[(Shaper, &str)] = &[
+        (Shaper::Soft, "SOFT"),
+        (Shaper::Hard, "HARD"),
+        (Shaper::Fold, "FOLD"),
+    ];
