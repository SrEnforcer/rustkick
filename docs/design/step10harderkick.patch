+/// Antiderivative of the sine wavefolder f(x) = sin(x * π/2):
+/// F(x) = -(2/π) * cos(x * π/2)
+#[inline]
+fn fold_antiderivative(x: f32) -> f32 {
+    -(2.0 / PI) * (x * PI * 0.5).cos()
 }
 
